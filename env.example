# Appwrite Configuration
# Copy this file to .env and fill in your actual values

# Appwrite API Endpoint
# For Appwrite Cloud: https://cloud.appwrite.io/v1
# For Self-hosted: http://your-domain/v1
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID
# Get this from: Appwrite Console → Settings → General
VITE_APPWRITE_PROJECT=your_project_id_here

# Your Appwrite Database ID
# Get this from: Appwrite Console → Databases → [Your Database Name]
VITE_APPWRITE_DATABASE_ID=your_database_id_here

# Your Appwrite Projects Collection ID
# Get this from: Appwrite Console → Databases → [Your Database] → Collections → projects
VITE_APPWRITE_PROJECTS_COLLECTION_ID=your_projects_collection_id_here

# Your Appwrite Contacts Collection ID
# Get this from: Appwrite Console → Databases → [Your Database] → Collections → contacts
VITE_APPWRITE_CONTACTS_COLLECTION_ID=your_contacts_collection_id_here

# Your Appwrite Storage Bucket ID
# Get this from: Appwrite Console → Storage → [Your Bucket Name]
VITE_APPWRITE_BUCKET_ID=your_bucket_id_here

# Optional: API Key for admin operations (backend only, never expose in client)
# Get this from: Appwrite Console → Settings → API Keys
APPWRITE_API_KEY=your_api_key_here

# Optional: Enable debug mode
VITE_DEBUG=false
