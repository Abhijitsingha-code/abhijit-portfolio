# Sanity Configuration
# Copy this file to .env and fill in your actual values

# Your Sanity Project ID
# Get this from: sanity.io/manage → your project → Settings → API
VITE_SANITY_PROJECT_ID=your_project_id_here

# Sanity Dataset name (usually "production")
VITE_SANITY_DATASET=production

# Sanity API Version — use the current date (YYYY-MM-DD)
# See: https://www.sanity.io/docs/api-versioning
VITE_SANITY_API_VERSION=2024-01-01

# ── EmailJS (Contact form) ────────────────────────────────────────────────────
# Get credentials from: https://emailjs.com → Account → Email Services / Templates
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
